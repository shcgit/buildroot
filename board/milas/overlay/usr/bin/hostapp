#!/bin/bash

gpiobase()
{
	if [ -d /sys/class/gpio ]; then
		for gpiochip in /sys/class/gpio/gpiochip* ; do
			label=$(cat "$gpiochip/label")
			base=$(cat "$gpiochip/base")
			if [ "$label" = "$1" ]; then
				printf "%d" $((base + $2))
				return
			fi
		done
	fi

	printf "0"
}

gpioexport()
{
	local cfg=0
	local i=0
	while [ "$i" -lt "$2" ]; do
		local gpio=$(( $1 + i ))

		if [ ! -d "/sys/class/gpio/gpio$gpio" ]; then
			echo "$gpio" > /sys/class/gpio/export 2>/dev/null
		fi

		if [ -d "/sys/class/gpio/gpio$gpio" ]; then
			echo "in" > "/sys/class/gpio/gpio$gpio/direction" 2>/dev/null
			val=$(cat "/sys/class/gpio/gpio$gpio/value")
			cfg=$(( cfg | (val << i) ))
		fi

		i=$((i + 1))
	done

	printf "%d" "$cfg"
}

gpiofind()
{
	local base
	base=$(gpiobase "$1" "$2")
	if [ "$base" -ne 0 ]; then
		gpioexport "$base" "$3"
	fi
}

selectapp()
{
	case "$1" in
	"9" | "10" )
		printf "spider"
	;;
	* )
		printf "informer"
	;;
	esac

	exit 0
}

cfg=$(gpiofind "10200000.bgpio" 4 4)
if [ -n "$cfg" ] && [ "$cfg" -ne 0 ]; then
	selectapp "$cfg"
fi

cfg=$(gpiofind "cc000000.bgpio" 0 8)
if [ -n "$cfg" ] && [ "$cfg" -ne 0 ]; then
	selectapp "$cfg"
fi

cfg=$(gpiofind "0-0020" 0 5)
if [ -n "$cfg" ] && [ "$cfg" -ne 0 ]; then
	selectapp "$cfg"
fi

printf ""

exit 0
